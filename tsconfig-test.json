{
    "compilerOptions": {
        "downlevelIteration": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "target": "es5",
        "module": "commonjs",
        "sourceMap": true,
        "declaration": true,
        "outDir": "dist",
        "noImplicitAny": true,
        "noImplicitThis": true,
        "strict": true,
        "typeRoots": [
            "node_modules/@types"
        ],
        "types": [
            "jasmine"
        ],
        "lib": [
            "dom",
            "scripthost",
            "es2015",
            "es2016.array.include"
        ],
        "baseUrl": "./",
        "paths": {
            "@elements": ["src/elements"],
            "@metadata": ["src/metadata"],
            "@sandbox": ["src/sandbox"],
            "@sample-types": ["src/playground/types"]
        }
    },
    "include": [
        "./src/**/*.ts",
        "./test/**/*.ts"
    ]
}