{
    "name": "entity-space",
    "version": "2.0.0-alpha.0",
    "license": "MIT",
    "private": true,
    "scripts": {
        "postinstall": "ngcc --properties es2015 browser module main",
        "test": "npm run test:types && npm run test:libs",
        "test:libs": "npx nx run-many --parallel --target=test --projects=utils,lexer,criteria,core --silent",
        "test:types": "npm run test:types:criteria && npm run test:types:core",
        "test:types:criteria": "dtslint --localTs node_modules/typescript/lib packages/criteria/src/test/types",
        "test:types:core": "dtslint --localTs node_modules/typescript/lib packages/core/src/test/types"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/kukeiko/entity-space"
    },
    "dependencies": {
        "@angular/animations": "~13.1.0",
        "@angular/cdk": "^13.1.2",
        "@angular/common": "~13.1.0",
        "@angular/compiler": "~13.1.0",
        "@angular/core": "~13.1.0",
        "@angular/forms": "~13.1.0",
        "@angular/material": "^13.1.2",
        "@angular/platform-browser": "~13.1.0",
        "@angular/platform-browser-dynamic": "~13.1.0",
        "@angular/router": "~13.1.0",
        "@nestjs/common": "^8.0.0",
        "@nestjs/core": "^8.0.0",
        "@nestjs/platform-express": "^8.0.0",
        "reflect-metadata": "^0.1.13",
        "rxjs": "~7.4.0",
        "tslib": "^2.0.0",
        "zone.js": "~0.11.4"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "~13.1.0",
        "@angular-eslint/eslint-plugin": "~13.0.1",
        "@angular-eslint/eslint-plugin-template": "~13.0.1",
        "@angular-eslint/template-parser": "~13.0.1",
        "@angular/cli": "~13.1.0",
        "@angular/compiler-cli": "~13.1.0",
        "@angular/language-service": "~13.1.0",
        "@nestjs/schematics": "^8.0.0",
        "@nestjs/testing": "^8.0.0",
        "@nrwl/angular": "^13.4.1",
        "@nrwl/cli": "13.4.1",
        "@nrwl/eslint-plugin-nx": "13.4.1",
        "@nrwl/jest": "13.4.1",
        "@nrwl/js": "13.4.1",
        "@nrwl/linter": "13.4.1",
        "@nrwl/nest": "^13.4.1",
        "@nrwl/node": "13.4.1",
        "@nrwl/tao": "13.4.1",
        "@nrwl/workspace": "13.4.1",
        "@types/jest": "27.0.2",
        "@types/node": "14.14.33",
        "@typescript-eslint/eslint-plugin": "~5.3.0",
        "@typescript-eslint/parser": "~5.3.0",
        "commitizen": "4.2.4",
        "conditional-type-checks": "1.0.5",
        "cz-customizable": "6.3.0",
        "dtslint": "4.2.1",
        "eslint": "8.2.0",
        "eslint-config-prettier": "8.1.0",
        "eslint-plugin-cypress": "^2.10.3",
        "jest": "27.2.3",
        "jest-preset-angular": "11.0.0",
        "prettier": "^2.3.1",
        "prettier-plugin-organize-imports": "^2.3.4",
        "ts-jest": "27.0.5",
        "tslint": "6.1.3",
        "typescript": "~4.4.3"
    },
    "config": {
