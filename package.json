{
    "name": "entity-space",
    "version": "2.0.0-alpha.0",
    "license": "MIT",
    "private": true,
    "scripts": {
        "postinstall": "ngcc --properties es2015 browser module main",
        "test": "npm run test:types && npm run test:libs",
        "test:libs": "npx nx run-many --parallel --target=test --projects=utils,lexer,criteria,core --silent --codeCoverage",
        "test:types": "npm run test:types:criteria && npm run test:types:core",
        "test:types:criteria": "dtslint --localTs node_modules/typescript/lib packages/criteria/src/test/types",
        "test:types:core": "dtslint --localTs node_modules/typescript/lib packages/core/src/test/types"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/kukeiko/entity-space"
    },
    "dependencies": {
        "@angular/animations": "13.3.8",
        "@angular/cdk": "13.3.7",
        "@angular/common": "13.3.8",
        "@angular/compiler": "13.3.8",
        "@angular/core": "13.3.8",
        "@angular/forms": "13.3.8",
        "@angular/material": "13.3.7",
        "@angular/platform-browser": "13.3.8",
        "@angular/platform-browser-dynamic": "13.3.8",
        "@angular/router": "13.3.8",
        "@nestjs/common": "^8.0.0",
        "@nestjs/core": "^8.0.0",
        "@nestjs/platform-express": "^8.0.0",
        "lodash": "4.17.21",
        "primeicons": "^5.0.0",
        "primeng": "^13.4.0",
        "primeflex": "3.2.0",
        "reflect-metadata": "^0.1.13",
        "rxjs": "~7.4.0",
        "tslib": "^2.0.0",
        "zone.js": "~0.11.4"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "13.3.5",
        "@angular-eslint/eslint-plugin": "~13.0.1",
        "@angular-eslint/eslint-plugin-template": "~13.0.1",
        "@angular-eslint/template-parser": "~13.0.1",
        "@angular/cli": "13.3.5",
        "@angular/compiler-cli": "13.3.8",
        "@angular/language-service": "13.3.8",
        "@nestjs/schematics": "^8.0.0",
        "@nestjs/testing": "^8.0.0",
        "@nrwl/angular": "14.1.5",
        "@nrwl/eslint-plugin-nx": "14.1.5",
        "@nrwl/jest": "14.1.5",
        "@nrwl/js": "14.1.5",
        "@nrwl/linter": "14.1.5",
        "@nrwl/nest": "14.1.5",
        "@nrwl/node": "14.1.5",
        "@nrwl/workspace": "14.1.5",
        "@types/jest": "27.4.1",
        "@types/node": "14.14.33",
        "@types/lodash": "4.14.182",
        "@typescript-eslint/eslint-plugin": "5.18.0",
        "@typescript-eslint/parser": "5.18.0",
        "@typescript/analyze-trace": "0.9.0",
        "commitizen": "4.2.4",
        "conditional-type-checks": "1.0.5",
        "cz-customizable": "6.3.0",
        "dtslint": "4.2.1",
        "eslint": "8.12.0",
        "eslint-config-prettier": "8.1.0",
        "eslint-plugin-cypress": "^2.10.3",
        "jest": "27.5.1",
        "jest-preset-angular": "11.1.1",
        "nx": "14.1.5",
        "prettier": "2.5.1",
        "prettier-plugin-organize-imports": "^2.3.4",
        "ts-jest": "27.1.4",
        "ts-node": "9.1.1",
        "tslint": "6.1.3",
        "typescript": "4.6.4"
