{
    "name": "entity-space",
    "version": "2.0.0-alpha.0",
    "description": "Strictly typed data framework for consuming HTTP services",
    "author": "Magna Marek",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/kukeiko/entity-space"
    },
    "typings": "./dist/src/index.d.ts",
    "main": "./dist/src/index",
    "scripts": {
        "build": "rimraf dist && tsc",
        "build:watch": "tsc -w",
        "test": "karma start --single-run",
        "test:watch": "karma start",
        "test:debug": "karma start",
        "npmprepublish": "npm run build && npm run test",
        "lint": "tslint --project . --format codeFrame",
        "commit": "git-cz",
        "test-types": "dtslint ./test/types"
    },
    "dependencies": {
        "reflect-metadata": "0.1.12",
        "rxjs": "6.x.x"
    },
    "peerDependencies": {},
    "devDependencies": {
        "@types/jasmine": "3.5.0",
        "commitizen": "4.0.3",
        "conditional-type-checks": "1.0.5",
        "cz-customizable": "6.2.0",
        "dtslint": "4.0.9",
        "istanbul-instrumenter-loader": "3.0.1",
        "jasmine-core": "3.5.0",
        "karma": "4.4.1",
        "karma-chrome-launcher": "3.1.0",
        "karma-coverage-istanbul-reporter": "2.1.1",
        "karma-jasmine": "2.0.1",
        "karma-mocha-reporter": "2.2.5",
        "karma-sourcemap-loader": "0.3.7",
        "karma-webpack": "4.0.2",
        "prettier": "2.0.5",
        "puppeteer": "2.0.0",
        "rimraf": "3.0.0",
        "ts-loader": "6.2.1",
        "tslint": "6.1.3",
        "typescript": "4.2.3",
        "webpack": "4.41.4"
    },
    "config": {
        "commitizen": {
            "path": "node_modules/cz-customizable"
        },
        "cz-customizable": {
            "config": "./.cz-config.js"
        }
    }
}
