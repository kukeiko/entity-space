{
    "name": "entity-space",
    "version": "2.0.0-alpha.0",
    "description": "Strictly typed data framework for consuming HTTP services",
    "author": "Magna Marek",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/kukeiko/entity-space"
    },
    "typings": "./dist/src/index.d.ts",
    "main": "./dist/src/index",
    "scripts": {
        "build": "rimraf dist && tsc",
        "build:watch": "tsc -w",
        "commit": "npm run lint && npm run commitizen",
        "commitizen": "git-cz",
        "lint": "eslint .",
        "npmprepublish": "npm run build && npm run test",
        "test": "npm run test:types && karma start --single-run",
        "test:debug": "karma start",
        "test:types": "dtslint --localTs node_modules/typescript/lib ./test/types",
        "test:watch": "karma start"
    },
    "dependencies": {
        "reflect-metadata": "0.1.12",
        "rxjs": "6.x.x"
    },
    "peerDependencies": {},
    "devDependencies": {
        "@types/jasmine": "3.6.10",
        "@typescript-eslint/eslint-plugin": "^4.25.0",
        "@typescript-eslint/parser": "^4.25.0",
        "commitizen": "4.2.4",
        "conditional-type-checks": "1.0.5",
        "cz-customizable": "6.3.0",
        "dtslint": "4.1.3",
        "eslint": "7.27.0",
        "istanbul-instrumenter-loader": "3.0.1",
        "jasmine-core": "3.7.1",
        "karma": "6.3.2",
        "karma-chrome-launcher": "3.1.0",
        "karma-coverage-istanbul-reporter": "3.0.3",
        "karma-jasmine": "4.0.1",
        "karma-mocha-reporter": "2.2.5",
        "karma-sourcemap-loader": "0.3.8",
        "karma-webpack": "5.0.0",
        "prettier": "2.3.2",
        "puppeteer": "9.0.0",
        "rimraf": "3.0.0",
        "ts-loader": "9.1.1",
        "tslint": "6.1.3",
        "typescript": "4.4.4",
        "webpack": "5.36.2"
    },
    "config": {
        "commitizen": {
            "path": "node_modules/cz-customizable"
        },
        "cz-customizable": {
            "config": "./.cz-config.js"
        }
    }
}
