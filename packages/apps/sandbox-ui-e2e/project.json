{
    "root": "packages/apps/sandbox-ui-e2e",
    "sourceRoot": "packages/apps/sandbox-ui-e2e/src",
    "projectType": "application",
    "targets": {
        "e2e": {
            "executor": "@nrwl/cypress:cypress",
            "options": {
                "cypressConfig": "packages/apps/sandbox-ui-e2e/cypress.json",
                "devServerTarget": "apps-sandbox-ui:serve:development"
            },
            "configurations": {
                "production": {
                    "devServerTarget": "apps-sandbox-ui:serve:production"
                }
            }
        },
        "lint": {
            "executor": "@nrwl/linter:eslint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": ["packages/apps/sandbox-ui-e2e/**/*.{js,ts}"]
            }
        }
    },
    "tags": [],
    "implicitDependencies": ["apps-sandbox-ui"]
}
