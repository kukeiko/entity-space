{
    "projectType": "application",
    "root": "packages/apps/sandbox-ui",
    "sourceRoot": "packages/apps/sandbox-ui/src",
    "prefix": "entity-space",
    "targets": {
        "build": {
            "executor": "@angular-devkit/build-angular:browser",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/packages/apps/sandbox-ui",
                "index": "packages/apps/sandbox-ui/src/index.html",
                "main": "packages/apps/sandbox-ui/src/main.ts",
                "polyfills": "packages/apps/sandbox-ui/src/polyfills.ts",
                "tsConfig": "packages/apps/sandbox-ui/tsconfig.app.json",
                "inlineStyleLanguage": "scss",
                "assets": ["packages/apps/sandbox-ui/src/favicon.ico", "packages/apps/sandbox-ui/src/assets"],
                "styles": ["packages/apps/sandbox-ui/src/styles.scss"],
                "scripts": []
            },
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "500kb",
                            "maximumError": "1mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "2kb",
                            "maximumError": "4kb"
                        }
                    ],
                    "fileReplacements": [
                        {
                            "replace": "packages/apps/sandbox-ui/src/environments/environment.ts",
                            "with": "packages/apps/sandbox-ui/src/environments/environment.prod.ts"
                        }
                    ],
                    "outputHashing": "all"
                },
                "development": {
                    "buildOptimizer": false,
                    "optimization": false,
                    "vendorChunk": true,
                    "extractLicenses": false,
                    "sourceMap": true,
                    "namedChunks": true
                }
            },
            "defaultConfiguration": "production"
        },
        "serve": {
            "executor": "@angular-devkit/build-angular:dev-server",
            "configurations": {
                "production": {
                    "browserTarget": "apps-sandbox-ui:build:production"
                },
                "development": {
                    "browserTarget": "apps-sandbox-ui:build:development"
                }
            },
            "defaultConfiguration": "development",
            "options": {
                "port": 7000,
                "browserTarget": "apps-sandbox-ui:build:development"
            }
        },
        "extract-i18n": {
            "executor": "@angular-devkit/build-angular:extract-i18n",
            "options": {
                "browserTarget": "apps-sandbox-ui:build"
            }
        },
        "lint": {
            "executor": "@nrwl/linter:eslint",
            "options": {
                "lintFilePatterns": ["packages/apps/sandbox-ui/src/**/*.ts", "packages/apps/sandbox-ui/src/**/*.html"]
            }
        },
        "test": {
            "executor": "@nrwl/jest:jest",
            "outputs": ["coverage/packages/apps/sandbox-ui"],
            "options": {
                "jestConfig": "packages/apps/sandbox-ui/jest.config.js",
                "passWithNoTests": true
            }
        }
    },
    "tags": []
}
