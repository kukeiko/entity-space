{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/lexer/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "@nrwl/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/packages/lexer",
                "main": "packages/lexer/src/index.ts",
                "tsConfig": "packages/lexer/tsconfig.lib.json",
                "assets": ["packages/lexer/*.md"]
            }
        },
        "lint": {
            "executor": "@nrwl/linter:eslint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": ["packages/lexer/**/*.ts"]
            }
        },
        "test": {
            "executor": "@nrwl/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/packages/lexer"],
            "options": {
                "jestConfig": "packages/lexer/jest.config.ts",
                "passWithNoTests": true
            }
        }
    },
    "tags": []
}
