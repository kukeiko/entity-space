{
    "projectType": "application",
    "root": "packages/examples/products/apps/products-ui",
    "sourceRoot": "packages/examples/products/apps/products-ui/src",
    "prefix": "entity-space",
    "targets": {
        "build": {
            "executor": "@angular-devkit/build-angular:browser",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/packages/examples/products/apps/products-ui",
                "index": "packages/examples/products/apps/products-ui/src/index.html",
                "main": "packages/examples/products/apps/products-ui/src/main.ts",
                "polyfills": "packages/examples/products/apps/products-ui/src/polyfills.ts",
                "tsConfig": "packages/examples/products/apps/products-ui/tsconfig.app.json",
                "inlineStyleLanguage": "scss",
                "assets": [
                    "packages/examples/products/apps/products-ui/src/favicon.ico",
                    "packages/examples/products/apps/products-ui/src/assets"
                ],
                "styles": ["packages/examples/products/apps/products-ui/src/styles.scss"],
                "scripts": []
            },
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "500kb",
                            "maximumError": "1mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "2kb",
                            "maximumError": "4kb"
                        }
                    ],
                    "fileReplacements": [
                        {
                            "replace": "packages/examples/products/apps/products-ui/src/environments/environment.ts",
                            "with": "packages/examples/products/apps/products-ui/src/environments/environment.prod.ts"
                        }
                    ],
                    "outputHashing": "all"
                },
                "development": {
                    "buildOptimizer": false,
                    "optimization": false,
                    "vendorChunk": true,
                    "extractLicenses": false,
                    "sourceMap": true,
                    "namedChunks": true
                }
            },
            "defaultConfiguration": "production"
        },
        "serve": {
            "executor": "@angular-devkit/build-angular:dev-server",
            "configurations": {
                "production": {
                    "browserTarget": "examples-products-apps-products-ui:build:production"
                },
                "development": {
                    "browserTarget": "examples-products-apps-products-ui:build:development"
                }
            },
            "defaultConfiguration": "development",
            "options": {
                "proxyConfig": "packages/examples/products/apps/products-ui/proxy.conf.json"
            }
        },
        "extract-i18n": {
            "executor": "@angular-devkit/build-angular:extract-i18n",
            "options": {
                "browserTarget": "examples-products-apps-products-ui:build"
            }
        },
        "lint": {
            "executor": "@nrwl/linter:eslint",
            "options": {
                "lintFilePatterns": [
                    "packages/examples/products/apps/products-ui/src/**/*.ts",
                    "packages/examples/products/apps/products-ui/src/**/*.html"
                ]
            }
        },
        "test": {
            "executor": "@nrwl/jest:jest",
            "outputs": ["coverage/packages/examples/products/apps/products-ui"],
            "options": {
                "jestConfig": "packages/examples/products/apps/products-ui/jest.config.js",
                "passWithNoTests": true
            }
        }
    },
    "tags": []
}
