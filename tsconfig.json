{
    "compilerOptions": {
        "downlevelIteration": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "target": "es5",
        "module": "commonjs",
        "sourceMap": true,
        "declaration": true,
        "outDir": "dist",
        "noImplicitAny": true,
        "noImplicitThis": true,
        "resolveJsonModule": true,
        "strict": true,
        "lib": ["DOM", "scripthost", "ES2020"],
        "baseUrl": ".",
        "paths": { "@entity-space/utils": ["src/utils/public.ts"], "@entity-space/core": ["src/core/public.ts"], "@entity-space/model": ["src/model/public.ts"] }
    },
    "include": ["./src/**/*.ts", "./test/**/*.ts"]
}
